# Скопируй этот файл в .env и заполни

# Токен от @BotFather
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL где будет жить сервер (должен быть HTTPS для Telegram Mini App)
# Например: https://your-app.railway.app
WEBAPP_URL=https://your-domain.com

# Путь к SQLite базе (можно оставить как есть)
DB_PATH=budget.db

# Порт сервера
PORT=8000
